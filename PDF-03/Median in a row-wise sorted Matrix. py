'''Given a row-wise sorted matrix mat[][] of size n*m, where the number of rows and 
columns is always odd. Return the median of the matrix.
Examples:
Input: mat[][] = [[1, 3, 5], 
 [2, 6, 9], 
 [3, 6, 9]]
Output: 5
Explanation: Sorting matrix elements gives us [1, 2, 3, 3, 5, 6, 6, 9, 9]. Hence, 5 is 
median.
Input: mat[][] = [[2, 4, 9],
 [3, 6, 7],
 [4, 7, 10]]
Output: 6
Explanation: Sorting matrix elements gives us [2, 3, 4, 4, 6, 7, 7, 9, 10]. Hence, 6 is 
median.
Input: mat = [[3], [4], [8]]
Output: 4
Explanation: Sorting matrix elements gives us [3, 4, 8]. Hence, 4 is median.'''

def matrixMedian(mat):
    arr = []

    for row in mat:
        arr.extend(row)

    arr.sort()

    n = len(arr)

    return arr[n // 2]


n = int(input("Enter number of rows: "))
m = int(input("Enter number of columns: "))

mat = []
print("Enter matrix elements:")

for i in range(n):
    row = list(map(int, input().split()))
    mat.append(row)

print("Median:", matrixMedian(mat))
